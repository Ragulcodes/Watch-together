# --- Database ---
# Local: one URL is enough.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/watch_together?schema=public"
# Serverless (Vercel + Neon): set DATABASE_URL to the POOLED string (host has
# "-pooler") for app runtime, and DIRECT_URL to the NON-pooled string — the
# Vercel build runs `prisma migrate deploy` over DIRECT_URL. Locally, leave
# DIRECT_URL unset (the build command falls back to DATABASE_URL).
# DIRECT_URL="postgresql://USER:PASS@HOST.neon.tech/watch_together?sslmode=require"

# --- NextAuth ---
NEXTAUTH_URL="http://localhost:3030"
NEXTAUTH_SECRET="change-me-generate-with-openssl-rand-base64-32"

# --- LiveKit (get free dev keys at https://cloud.livekit.io) ---
LIVEKIT_API_KEY="devkey"
LIVEKIT_API_SECRET="devsecretdevsecretdevsecretdevsecret"
LIVEKIT_URL="wss://your-project.livekit.cloud"
NEXT_PUBLIC_LIVEKIT_URL="wss://your-project.livekit.cloud"
