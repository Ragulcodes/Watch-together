generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String        @id @default(cuid())
  email         String        @unique
  username      String        @unique
  displayName   String
  passwordHash  String
  avatarUrl     String?
  createdAt     DateTime      @default(now())
  rooms         Room[]        @relation("RoomOwner")
  memberships   Membership[]
  messages      Message[]
}

model Room {
  id            String        @id @default(cuid())
  slug          String        @unique
  name          String
  description   String?
  isPrivate     Boolean       @default(false)
  passcodeHash  String?
  ownerId       String
  owner         User          @relation("RoomOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  createdAt     DateTime      @default(now())
  // Current synced playback state
  mediaUrl      String?
  mediaTitle    String?
  isPlaying     Boolean       @default(false)
  positionSec   Float         @default(0)
  positionAt    DateTime      @default(now())
  // Recording (LiveKit Egress)
  recordingEgressId   String?
  recordingStartedAt  DateTime?
  memberships   Membership[]
  messages      Message[]

  @@index([ownerId])
}

model Membership {
  id        String   @id @default(cuid())
  userId    String
  roomId    String
  role      String   @default("member") // owner | host | member
  joinedAt  DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  room      Room     @relation(fields: [roomId], references: [id], onDelete: Cascade)

  @@unique([userId, roomId])
  @@index([roomId])
}

model Message {
  id        String   @id @default(cuid())
  roomId    String
  userId    String
  body      String
  createdAt DateTime @default(now())
  room      Room     @relation(fields: [roomId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([roomId, createdAt])
}

// "Movies we've watched together" + total time watched (shown on the welcome page).
model WatchHistory {
  id        String   @id @default(cuid())
  title     String
  url       String?
  seconds   Int      @default(0)
  startedAt DateTime @default(now())

  @@index([startedAt])
}
